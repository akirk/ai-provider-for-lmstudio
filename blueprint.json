{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"meta": {
		"title": "AI Provider for LM Studio",
		"description": "LM Studio provider for the WordPress AI Client (git version)",
		"author": "Alex Kirk"
	},
	"login": true,
	"steps": [
		{
			"step": "installPlugin",
			"pluginData": {
				"resource": "git:directory",
				"url": "https://github.com/akirk/ai-provider-for-lmstudio",
				"ref": "main",
				"refType": "branch"
			},
			"options": {
				"targetFolderName": "ai-provider-for-lmstudio"
			}
		}
	]
}
